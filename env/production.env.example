# Copy to env/production.env and fill in. The real file is gitignored.
#
# Production env: rpai uses the default profile (no RPAI_ENV needed).
# Find your cluster's IDs / URLs via the Cloud UI or the controlplane API:
#   curl -H "Authorization: Bearer $(rpai auth token)" \
#     https://api.redpanda.com/v1/clusters/<CLUSTER_ID>

ENV_NAME=production
RPAI_ENV=
RPAI_PROFILE=default

CLUSTER_ID=<your-cluster-id>
RESOURCE_GROUP_ID=<your-resource-group-uuid>

DATAPLANE_API=https://api-<random>.<CLUSTER_ID>.byoc.prd.cloud.redpanda.com
CONTROLPLANE_API=https://api.redpanda.com
AIGW_URL=https://aigw.<CLUSTER_ID>.clusters.rdpa.co
ADP_API_URL=https://adp-api.<CLUSTER_ID>.clusters.rdpa.co

# aigw LLMProvider name on this cluster (must already exist + allow the model below)
LLM_PROVIDER=anthropic-api-key
LLM_MODEL=claude-sonnet-4-6

# Salesforce dev org. Connected App must be configured for client_credentials
# with a Run-As user; client_id is the Consumer Key.
SF_ORG_URL=https://<your-org-subdomain>.develop.my.salesforce.com
SF_API_VERSION=v65.0
SF_CLIENT_ID=<your-connected-app-consumer-key>

# Stable resource names — usually fine as-is
MCP_NAME=salesforce
SA_NAME=telco-crm-agent
AGENT_DISPLAY_NAME="Telco CRM Agent"
SF_SECRET_NAME=SF_CLIENT_SECRET
