# Copy to env/integration.env and fill in. The real file is gitignored.
#
# Find your cluster's IDs / URLs by either:
#   - Looking at it in the Cloud UI:
#       https://main--redpanda-cloud.netlify.app/clusters/<CLUSTER_ID>
#   - Or via the controlplane API:
#       curl -H "Authorization: Bearer $(RPAI_ENV=integration rpai auth token)" \
#         https://api.ign.cloud.redpanda.com/v1/clusters/<CLUSTER_ID>
#       and pluck .cluster.dataplane_api.url + .cluster.resource_group_id

ENV_NAME=integration
RPAI_ENV=integration
RPAI_PROFILE=integration

CLUSTER_ID=<your-cluster-id>
RESOURCE_GROUP_ID=<your-resource-group-uuid>

DATAPLANE_API=https://api-<random>.<CLUSTER_ID>.byoc.ign.cloud.redpanda.com
CONTROLPLANE_API=https://api.ign.cloud.redpanda.com
AIGW_URL=https://aigw.<CLUSTER_ID>.clusters.ign.rdpa.co
ADP_API_URL=https://adp-api.<CLUSTER_ID>.clusters.ign.rdpa.co

# aigw LLMProvider name on this cluster (must already exist + allow the model below)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Salesforce dev org. Connected App must be configured for client_credentials
# with a Run-As user; client_id is the Consumer Key.
SF_ORG_URL=https://<your-org-subdomain>.develop.my.salesforce.com
SF_API_VERSION=v65.0
SF_CLIENT_ID=<your-connected-app-consumer-key>

# Stable resource names — usually fine as-is
MCP_NAME=salesforce
SA_NAME=telco-crm-agent
AGENT_DISPLAY_NAME="Telco CRM Agent"
SF_SECRET_NAME=SF_CLIENT_SECRET
